{
  "compilerOptions": {
    "strict": true,
    "module": "commonjs",
    "target": "es2022",
    "lib": ["es2022", "dom"],
    "declaration": true,
    "outDir": "./dist",
    "rootDir": ".",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  "include": ["credentials/**/*.ts", "nodes/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
